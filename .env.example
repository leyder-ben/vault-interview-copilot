# Database
DATABASE_URL=postgresql+psycopg://copilot:copilot@localhost:5432/vault_copilot

# Ollama provider endpoints — registered once, switched at runtime via
# the settings table, not by editing this file.
# See docs/adr/ for the reasoning (provider hosting decision, 2026-07-14).
OLLAMA_WORKSTATION_URL=http://localhost:11434
OLLAMA_AI_INFERENCE_URL=http://<ai-inference-vm-reserved-ip>:11434

# Models
GENERATION_MODEL=gpt-oss:20b
EMBEDDING_MODEL=nomic-embed-text

# Chunking
# Oversized-section fallback threshold (tokens, tiktoken cl100k_base
# approximation). Tune from evaluation results without a code change.
CHUNK_MAX_SECTION_TOKENS=400

# Vault path (read-only mount)
VAULT_PATH=/path/to/obsidian-vault

# Query logging — on by default, purge via DELETE FROM query_runs
# or set QUERY_LOGGING=false for a one-off private run.
QUERY_LOGGING=true

# App
API_HOST=127.0.0.1
API_PORT=8000
LOG_LEVEL=info
