# Environment / secrets
.env
*.env.local

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Node / web
node_modules/
dist/
.vite/

# Docker
*.pid

# Database
*.sql.bak
pgdata/

# Real vault content — never committed, ever
/real-vault/
vault-data/

# Evaluation reports (generated, not source)
evaluation/reports/*
!evaluation/reports/.gitkeep

# Private evaluation fixtures (real vault content, real project names) —
# never committed. Sanitized fixtures for the public repo live in
# evaluation/datasets/sample-vault/ instead.
evaluation/datasets/private/

# Editor / OS
.vscode/
.idea/
.DS_Store
*.swp
